# ========================
# Application
# ========================
NODE_ENV=
API_PORT=
# keycloak or local
AUTH_MODE=

# ========================
# PostgreSQL
# ========================
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

DATABASE_URL=

# ========================
# Redis
# ========================
REDIS_HOST=
REDIS_PORT=
REDIS_URL=

# ========================
# RabbitMQ
# ========================
RABBITMQ_HOST=
RABBITMQ_PORT=
RABBITMQ_USER=
RABBITMQ_PASSWORD=

RABBITMQ_URL=

# ========================
# JWT (EPIC 3)
# ========================
JWT_SECRET=
JWT_EXPIRES_IN=

# ========================
# Keycloak (API)
# ========================
# OIDC_ISSUER=http://keycloak:8080/realms/opsdesk
# OIDC_AUDIENCE=opsdesk-api
# Required for Web UI Keycloak login (get from Keycloak Admin → Clients → opsdesk-api → Credentials)
# KEYCLOAK_CLIENT_SECRET=

# ========================
# Web UI (Vite env - used at build/runtime)
# ========================
# VITE_API_URL=/api
# VITE_WS_URL=http://localhost:8888
# VITE_AUTH_MODE=local
# VITE_OIDC_ISSUER=http://localhost:8080/realms/opsdesk