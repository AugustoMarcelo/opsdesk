{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Recent Logs by Service",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki-logs" },
      "targets": [
        {
          "expr": "{service=~\"api|worker|realtime\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 2,
      "title": "Log Lines per Second (by service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki-logs" },
      "targets": [
        {
          "expr": "sum by (service) (rate({service=~\"api|worker|realtime\"}[1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Log Lines Matching \"error\" per Minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki-logs" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\"api|worker|realtime\"} |= \"error\" [5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Logs by request_id (correlation)",
      "description": "Filter logs by request_id. Use a value from the x-request-id response header or a custom header you sent.",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki-logs" },
      "targets": [
        {
          "expr": "{service=\"api\"} |= \"${request_id}\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Ascending"
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["opsdesk", "logs", "loki"],
  "templating": {
    "list": [
      {
        "name": "request_id",
        "type": "textbox",
        "query": "",
        "label": "Request ID",
        "current": { "value": "", "text": "" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "title": "OpsDesk Logs",
  "uid": "opsdesk-logs",
  "version": 1,
  "weekStart": ""
}
